{
  "entities": {
    "Professional": {
      "title": "Professional",
      "description": "Tax professional or accountant",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["Administrador", "Contador"] }
      },
      "required": ["name", "email", "role"]
    },
    "Client": {
      "title": "Client",
      "description": "Taxpayer client",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "name": { "type": "string" },
        "cpf": { "type": "string" },
        "type": { "type": "string", "enum": ["PF", "SOCIO"] },
        "company": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "observations": { "type": "string" },
        "needs_declaration": { "type": "boolean" }
      },
      "required": ["name", "cpf", "type"]
    },
    "Declaration": {
      "title": "Declaration",
      "description": "Income tax declaration record",
      "type": "object",
      "properties": {
        "client_id": { "type": "string", "description": "Reference to client document ID" },
        "professional_id": { "type": "string", "description": "Reference to professional document ID" },
        "received_date": { "type": "string", "format": "date-time" },
        "completion_date": { "type": "string", "format": "date-time" },
        "transmission_date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Recebido", "Em Preenchimento", "Pendente Doc", "Concluído", "Transmitido"] },
        "has_tax_to_pay": { "type": "boolean" },
        "tax_amount": { "type": "number" }
      },
      "required": ["client_id", "status"]
    },
    "Call": {
      "title": "Call",
      "description": "Communication log with client",
      "type": "object",
      "properties": {
        "declaration_id": { "type": "string" },
        "professional_id": { "type": "string" },
        "call_date": { "type": "string", "format": "date-time" },
        "summary": { "type": "string" },
        "status_after_call": { "type": "string" }
      },
      "required": ["declaration_id", "professional_id", "call_date"]
    },
    "Attachment": {
      "title": "Attachment",
      "description": "File metadata for declarations",
      "type": "object",
      "properties": {
        "declaration_id": { "type": "string" },
        "filename": { "type": "string" },
        "original_name": { "type": "string" },
        "mime_type": { "type": "string" },
        "file_size": { "type": "number" },
        "upload_date": { "type": "string", "format": "date-time" }
      },
      "required": ["declaration_id", "filename", "original_name"]
    }
  },
  "firestore": {
    "/professionals/{profId}": {
      "schema": "Professional",
      "description": "Accounting team members"
    },
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "Taxpayer database"
    },
    "/declarations/{declId}": {
      "schema": "Declaration",
      "description": "Tax declarations tracking"
    },
    "/declarations/{declId}/calls/{callId}": {
      "schema": "Call",
      "description": "Call logs for a specific declaration"
    },
    "/declarations/{declId}/attachments/{attId}": {
      "schema": "Attachment",
      "description": "Files associated with a declaration"
    }
  }
}
